<script type="text/javascript">
(function(){ let me = window.gyLiveMainMgr = {
    playerControl : function(id, isPlay) {
    	if(document.getElementById(id) == null) return ;
        let iframe = document.getElementById(id).contentWindow;
        let dataJson = {};
        dataJson.fnName = "play";
        dataJson.isPlay = isPlay;
        iframe.postMessage(JSON.stringify(dataJson), "*");
    }

}})();


$(document).ready(function() {
    
    $(document).on('scroll', function() {
        $("#mainContainer ul.dv-shotPlayer").each(function() {
            let then = this;
            let isActive = $(then).hasClass("active");
            
            if(commonTool.isVisibleElemnet($(then))) {
                if(!isActive) {
                    $(this).find(".dv-mlc-live").each(function() {
                        let iframeId = $(this).find("iframe").attr("id");
                        gyLiveMainMgr.playerControl(iframeId, true);
                    });
                    
                    $(then).addClass("active");
                }
            } else {
                if(isActive) {
                    $(this).find(".dv-mlc-live").each(function() {
                        let iframeId = $(this).find("iframe").attr("id");
                        gyLiveMainMgr.playerControl(iframeId, false);
                    });
                    
                    $(then).removeClass("active");
                }
            }
        });
    });
    
    
});
</script>
