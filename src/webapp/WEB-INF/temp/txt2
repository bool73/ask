    <select id="selectScheduleIdByPrdId"  parameterType="TvShopVO"  resultType="TvShopVO">
    		/* [mapper-TvShop.xml][TvShopDAO.selectScheduleIdByPrdId][함계 방송하는 상품 편성표 ID 조회][CHEN] */
    		SELECT * FROM(
    			SELECT
    				   P.BRC_PGM_NM
    				  ,PPS.PRD_ID
    				  ,P.BRC_PGM_ID
    				  ,PPS.BRC_PGM_SCHDG_ID
    				  ,TO_CHAR(BRC_STD_DATE,'YYYYMMDD')											AS BRC_STD_DATE
    				  ,ABS(ROUND(SYSDATE - BRC_STD_DATE,0))										AS BRC_STD_DATE_SEQ
    				  ,(CASE WHEN SYSDATE <![CDATA[ > ]]> BRC_STD_DATE THEN '1' ELSE '0' END)	AS PREV_BROAD_CAST
    			FROM  TF_GOODS_RETRV GR ,
    				  TB_BC_BRC_PGM_SCHDG PS ,
    				  TB_BC_BRC_PGM_PRD_SCHDG PPS ,
    				  TB_BC_BRC_PGM P
    			WHERE GR.DEL_YN      = 'N'
    				AND GR.SALE_STAT_CD IN ('110', '120')
    				AND SYSDATE BETWEEN GR.SALE_PRC_STRT_DTIME AND GR.SALE_PRC_END_DTIME
    				AND PPS.PRD_ID     = GR.GOODS_NO
    				AND P.BRC_PGM_ID   = PS.BRC_PGM_ID
    			    AND P.USE_YN 	   = 'Y'
    				AND PS.CNF_YN      = 'Y'
    				AND PS.USE_YN      = 'Y'
    				AND PPS.USE_YN     = 'Y'
    				AND PS.BRC_PGM_SCHDG_ID = PPS.BRC_PGM_SCHDG_ID
    				AND PS.BRC_STD_DATE BETWEEN TO_DATE(TO_CHAR(SYSDATE,'YYYY-MM-DD'),'YYYY-MM-DD') - 5 AND TO_DATE(TO_CHAR(SYSDATE,'YYYY-MM-DD'),'YYYY-MM-DD') + 11
    				<if test="brcPgmSchdgId != null and brcPgmSchdgId !=''">
    					AND PS.BRC_PGM_SCHDG_ID = #{brcPgmSchdgId}
    				</if>
                    <if test="dlvExpctDateYn!= null and dlvExpctDateYn!=''">
                        AND SYSDATE BETWEEN (BRC_BGN_DTM - INTERVAL '3' HOUR)
                        AND (BRC_END_DTM + INTERVAL '30' MINUTE)
                    </if>
    				AND PPS.PRD_ID = #{prdId}
    				--AND P.BRC_PGM_ID != '10000976'
    			ORDER BY
    				PREV_BROAD_CAST ASC,
    				BRC_STD_DATE_SEQ ASC
    		) WHERE ROWNUM = 1
    	</select>