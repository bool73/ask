1) 배송예정일 구하기 전 먼저 아래 쿼리 실행
SELECT M.SUPLY_PLN_ID                                                                          AS SUPLY_PLN_ID
     , M.SPC_DUR_APPLY_YN                                                                      AS SPC_DUR_APPLY_YN
     , M.SPC_DUR_ADD_DLV_DDCNT                                                                 AS SPC_DUR_ADD_DLV_DDCNT
     , (GREATEST((SELECT NVL(MAX(STKO_EXPCT_DATE), TO_DATE('1900-01-01', 'YYYY-MM-DD'))
                    FROM TB_LO_SUPLY_PLN_DATE_QTY LSPDQ
                   WHERE LSPDQ.SUPLY_PLN_DTL_ID = M.SUPLY_PLN_DTL_ID
                     AND LSPDQ.SUPLY_PSS_QTY > 0),
                 (SELECT NVL(MAX(STKO_EXPCT_DATE), TO_DATE('1900-01-01', 'YYYY-MM-DD'))
                    FROM TB_LO_SUPLY_PLN_DATE_ADD_QTY LSPDQ
                   WHERE LSPDQ.SUPLY_PLN_DTL_ID = M.SUPLY_PLN_DTL_ID
                     AND LSPDQ.SUPLY_PSS_QTY > 0)))                                            AS STKO_EXPCT_DATE
     , M.BRC_STD_DATE                                                                          AS BRC_STD_DATE
--  INTO ln_suply_pln_id
--     , lv_spc_dur_apply_yn
--     , ln_spc_dur_add_dlv_ddcnt
--     , ldt_stko_expct_date
--     , ldt_brc_std_dtm
  FROM (
        SELECT SP.SUPLY_PLN_ID                     AS SUPLY_PLN_ID
             , SP.SPC_DUR_APPLY_YN                 AS SPC_DUR_APPLY_YN
             , NVL(SP.SPC_DUR_ADD_DLV_DDCNT, 0)    AS SPC_DUR_ADD_DLV_DDCNT
             , SPD.SUPLY_PLN_DTL_ID                AS SUPLY_PLN_DTL_ID
             , BPS.BRC_PGM_SCHDG_ID                AS BRC_PGM_SCHDG_ID
             , BPS.BRC_STD_DATE                    AS BRC_STD_DATE
          FROM TB_LO_SUPLY_PLN SP
          JOIN TB_LO_SUPLY_PLN_DTL SPD
            ON SP.SUPLY_PLN_ID      = SPD.SUPLY_PLN_ID
           AND SP.PRD_ID            = SPD.PRD_ID
          JOIN TB_PD_PRD PRD
            ON SP.PRD_ID            = PRD.PRD_ID
          JOIN TB_BC_BRC_PGM_SCHDG BPS
            ON SP.BRC_PGM_SCHDG_ID  = BPS.BRC_PGM_SCHDG_ID
          JOIN TB_BC_BRC_PGM_PRD_SCHDG BPPS
            ON SP.BRC_PGM_SCHDG_ID  = BPPS.BRC_PGM_SCHDG_ID
           AND SP.PRD_ID            = BPPS.PRD_ID
         WHERE SP.SUPLY_PLN_PGS_STS_CD = '400'
           AND SP.USE_YN = 'Y'
           AND SP.ORD_PSS_QTY_TRNSFR_YN = 'Y'
           AND PRD.DLV_CHRC_CD = '200'
           AND SPD.USE_YN = 'Y'
           AND BPS.CNF_YN = 'Y'
           AND BPS.USE_YN = 'Y'
           AND BPS.ONAIR_YN = 'N'
           AND ( (TRUNC(SYSDATE - 10) <= BPS.BRC_END_DTM) OR (TRUNC(SYSDATE - 10) <= BPS.RL_BRC_END_DTM) )  --결제 기준으로 10일 이내 방송
           AND BPPS.USE_YN = 'Y'
           AND SP.PRD_ID   = 11945619             --상품ID
           AND PRD.PRD_ID  = 11945619             --상품ID
         ORDER BY BPS.BRC_BGN_DTM DESC
       ) M
 WHERE ROWNUM = 1
;


