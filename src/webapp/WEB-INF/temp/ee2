3) 배송예정일 조회
SELECT A.PRD_ID                                                                                                                                        AS 상품ID
     , A.PRD_NM                                                                                                                                        AS 상품명
     , A.PRD_DCLS_ID                                                                                                                                   AS 상품세분류
     , A.PRD_TYP_CD                                                                                                                                    AS 상품구분      --[PRD_TYP_CD: 상품_구분_코드] 100: 방송상품, 200: 온라인상품, 300: 모바일라이브전용상품, 400: eTV전용상품
     , A.DLV_CHRC_CD                                                                                                                                   AS 배송특성      --[DLV_CHRC_CD: 배송_특성_코드] 200: 일반, 210: 주문제작, 220: 설치, 230: 여행, 240: 렌탈, 250: 보험, 260: 상조, 270: e쿠폰교환권, 280: e쿠폰금액권, 300: 예약판매
     , NVL(B.STNDRD_STKO_DDCNT, 0) + NVL(C.STNDRD_STKO_DDCNT, 0)                                                                                       AS 표준출고일

     , PG_LO_CM_UTIL.FN_LO_SS_GET_STD_STKO_DTM(A.PRD_ID, '1300', TO_DATE('20260619', 'YYYYMMDD'))                                                      AS 출고예정일자    --입력 날짜에 따라 출고예정일 계산
     , FN_SP_GET_DLV_DQTY(22244927, '03927')                                                                                                           AS 고객리드타임    --배송지ID 우선, 배송지ID없을경우 0, 우편번호없을경우 '0', 배송지ID와 우편번호 둘중 하나는 무조건 있어야 함
--     , FN_SP_GET_DLV_DQTY(22244927, '03927') + 1                                                                                                       AS 고객리드타임    --2)조건에 맞는경우 ln_spc_dur_add_dlv_ddcnt가 추가된 걸로 계산해야 함
     , FN_SP_GET_BIZ_ARRN_DTM(PG_LO_CM_UTIL.FN_LO_SS_GET_STD_STKO_DTM(A.PRD_ID, '1300', TO_DATE('20260619', 'YYYYMMDD')), FN_SP_GET_DLV_DQTY(22244927, '03927'), 'LO')  AS 배송예정일_최종
  FROM TB_PD_PRD A
 INNER
  JOIN TB_PD_PRD_CLS B
    ON A.PRD_DCLS_ID = B.PRD_CLS_ID
  LEFT
 OUTER
  JOIN TB_PD_PRD_CLS_STRG_STKO C
    ON A.PRD_DCLS_ID = C.PRD_CLS_ID
   AND A.PRD_STRG_PATTN_CD = C.PRD_STRG_PATTN_CD
 WHERE A.PRD_ID = 11922760             --상품ID
